CSC      = csc
CSCFLAGS = /optimize+ /warn:4

BUILD_DIR = build

SOURCES := $(wildcard HelloWorld_*.cs)
TARGETS := $(addprefix $(BUILD_DIR)/, $(basename $(SOURCES)).exe)

all: $(TARGETS)

$(BUILD_DIR)/%.exe: %.cs | $(BUILD_DIR)
	$(CSC) $(CSCFLAGS) /out:$@ $<

$(BUILD_DIR):
	if not exist $(BUILD_DIR) mkdir $(BUILD_DIR)

run: $(TARGETS)
	@for %i in ($(TARGETS)) do (echo === Running %i === & %i)

clean:
	if exist $(BUILD_DIR) rmdir /s /q $(BUILD_DIR)

.PHONY: all run clean
