CC       = gcc
CFLAGS   = -std=c17 -O2 -Wall -Wextra -pedantic
BUILD_DIR = build

SOURCES := $(wildcard HelloWorld_*.c)
TARGETS := $(addprefix $(BUILD_DIR)/, $(basename $(SOURCES)).exe)

all: $(TARGETS)

$(BUILD_DIR)/%.exe: %.c | $(BUILD_DIR)
	$(CC) $(CFLAGS) $< -o $@

$(BUILD_DIR):
	if not exist $(BUILD_DIR) mkdir $(BUILD_DIR)

run: $(TARGETS)
	@for %i in ($(TARGETS)) do (echo === Running %i === & %i)

clean:
	if exist $(BUILD_DIR) rmdir /s /q $(BUILD_DIR)

.PHONY: all run clean
